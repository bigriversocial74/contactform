  </defs>
  <rect width="1200" height="800" fill="url(#bg)"/>
  <circle cx="100" cy="110" r="180" fill="#60a5fa" opacity="0.16"/>
  <circle cx="1040" cy="700" r="240" fill="#f59e0b" opacity="0.16"/>
  <rect x="120" y="110" width="960" height="580" rx="42" fill="#fff7ed" filter="url(#shadow)"/>
  <rect x="780" y="135" width="240" height="70" rx="24" fill="#2563eb"/>
  <text x="900" y="181" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="36" font-weight="700" fill="#ffffff">SAVED</text>
  <g transform="translate(0,10)">
    <ellipse cx="360" cy="385" rx="118" ry="118" fill="#5b341f"/>
