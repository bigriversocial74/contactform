    <path d="M465 360c78-8 78 92 0 84" fill="none" stroke="#5b341f" stroke-width="24" stroke-linecap="round"/>
    <ellipse cx="840" cy="385" rx="118" ry="118" fill="#5b341f"/>
    <ellipse cx="840" cy="385" rx="88" ry="88" fill="#e8c98d"/>
