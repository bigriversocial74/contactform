<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="900" viewBox="0 0 1200 900" role="img" aria-label="Sleek SaaS UI with gold accents">
  <defs><linearGradient id="bg" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#070707"/><stop offset="1" stop-color="#17120a"/></linearGradient><linearGradient id="gold" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#d9a735"/><stop offset="1" stop-color="#f1c15a"/></linearGradient></defs>
  <rect width="1200" height="900" rx="42" fill="url(#bg)"/>
  <rect x="52" y="54" width="1096" height="792" rx="34" fill="#080808" stroke="#3b2b0a" stroke-width="3"/>
  <rect x="92" y="102" width="210" height="700" rx="28" fill="#0f0f0e" stroke="#2d220c"/>
  <circle cx="136" cy="152" r="18" fill="url(#gold)"/><text x="170" y="162" font-family="Arial" font-size="25" font-weight="900" fill="#fff">Microgifter</text>
  <g fill="#a7a39a" font-family="Arial" font-size="21"><text x="120" y="245">Campaigns</text><text x="120" y="305">Rewards</text><text x="120" y="365">Customers</text><text x="120" y="425">Analytics</text></g>
  <text x="350" y="150" font-family="Arial" font-size="42" font-weight="900" fill="#fff">Campaign Performance</text>
  <text x="350" y="196" font-family="Arial" font-size="23" fill="#a7a39a">Launch, track, and optimize local demand.</text>
  <g transform="translate(350 250)"><rect width="220" height="130" rx="26" fill="#111" stroke="#32250b"/><text x="26" y="54" font-family="Arial" font-size="21" fill="#a7a39a">Issued</text><text x="26" y="100" font-family="Arial" font-size="40" font-weight="900" fill="#fff">1,248</text></g>
  <g transform="translate(610 250)"><rect width="220" height="130" rx="26" fill="#111" stroke="#32250b"/><text x="26" y="54" font-family="Arial" font-size="21" fill="#a7a39a">Claims</text><text x="26" y="100" font-family="Arial" font-size="40" font-weight="900" fill="#f1c15a">742</text></g>
  <g transform="translate(870 250)"><rect width="220" height="130" rx="26" fill="#111" stroke="#32250b"/><text x="26" y="54" font-family="Arial" font-size="21" fill="#a7a39a">Revenue</text><text x="26" y="100" font-family="Arial" font-size="40" font-weight="900" fill="#fff">$18K</text></g>
  <rect x="350" y="430" width="740" height="260" rx="30" fill="#0f0f0e" stroke="#32250b"/>
  <path d="M390 640 L470 600 L550 614 L630 545 L710 570 L790 500 L870 526 L950 470 L1050 490" fill="none" stroke="url(#gold)" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
  <rect x="350" y="724" width="740" height="60" rx="18" fill="#111" stroke="#32250b"/><text x="382" y="763" font-family="Arial" font-size="24" font-weight="800" fill="#fff">Next best action: launch a limited brunch drop</text>
</svg>
