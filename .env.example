# Microgifter Stage 1 environment example
# Copy this to your host environment manager or server-local .env file.
# Never commit real secrets.

MG_APP_ENV=local
MG_DEBUG=true
MG_BASE_URL=http://localhost/microgifter
MG_TRUST_PROXY=false

# Runtime profiles: local, hostgator, staging, aws, production
MG_RUNTIME_PROFILE=hostgator

# Runtime feature flags
# HostGator/cPanel should keep polling + DB outbox enabled, but workers/Redis/websockets disabled.
MG_ENABLE_POLLING_NOTIFICATIONS=true
MG_ENABLE_DB_OUTBOX=true
MG_ENABLE_QUEUE_WORKER=false
MG_ENABLE_REDIS=false
MG_ENABLE_WEBSOCKETS=false
MG_ENABLE_SSE=false
MG_ENABLE_PWA_PUSH=true
MG_POLL_INTERVAL_SECONDS=15
MG_POLL_FAST_INTERVAL_SECONDS=5
MG_TRACKING_EVENT_RETENTION_DAYS=365
MG_PWA_PUSH_BATCH_SIZE=25

# PWA push notifications.
# Generate VAPID keys with your deployment tooling or WebPush provider setup.
# Never expose the private key in frontend code.
MG_PWA_VAPID_PUBLIC_KEY=
MG_PWA_VAPID_PRIVATE_KEY=
MG_PWA_VAPID_SUBJECT=mailto:admin@microgifter.com

MG_DB_HOST=localhost
MG_DB_NAME=microgifter
MG_DB_USER=microgifter_user
MG_DB_PASS=change_me
MG_DB_CHARSET=utf8mb4

MG_SESSION_NAME=mg_session
MG_SESSION_DAYS=30
MG_RESET_TOKEN_MINUTES=60
MG_VERIFY_TOKEN_MINUTES=1440

# Rate limits use database-backed identifiers and should be tuned per environment.
MG_RATE_LIMIT_LOGIN_MAX=8
MG_RATE_LIMIT_LOGIN_WINDOW=900
MG_RATE_LIMIT_REGISTER_MAX=10
MG_RATE_LIMIT_REGISTER_WINDOW=3600
MG_RATE_LIMIT_RECOVERY_MAX=5
MG_RATE_LIMIT_RECOVERY_WINDOW=3600
MG_RATE_LIMIT_PROFILE_MAX=20
MG_RATE_LIMIT_PROFILE_WINDOW=3600

# Production notes:
# MG_DEBUG=false
# MG_BASE_URL=https://microgifter.com
# MG_RUNTIME_PROFILE=aws or production when deployed to AWS production infrastructure.
# MG_TRUST_PROXY=true only when HTTPS/load-balancer proxy headers are controlled by your infrastructure.
# Use a strong database password.
# Serve over HTTPS only.
